# ─────────────────────────────────────────────────────────────────────────────
# SMTP Configuration
# Copy this file to .env and fill in your values.
# For Gmail: enable "App Passwords" under your Google Account security settings
#            and use the 16-char app password as SMTP_PASS.
# ─────────────────────────────────────────────────────────────────────────────

# SMTP server host
# Gmail  → smtp.gmail.com
# Outlook→ smtp.office365.com
# Custom → your mail provider's SMTP host
SMTP_HOST=smtp.gmail.com

# SMTP port
# 587 → STARTTLS (recommended)
# 465 → SSL/TLS  (set SMTP_SECURE=true)
SMTP_PORT=587

# Use SSL/TLS? Set true only when SMTP_PORT=465
SMTP_SECURE=false

# The email address used to authenticate with the SMTP server
SMTP_USER=your-email@gmail.com

# The password / app password for the SMTP account
SMTP_PASS=your-app-password-here

# The email address that receives contact form submissions
ADMIN_EMAIL=hello@bigbangtech.solutions
